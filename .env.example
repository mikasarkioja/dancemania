# Supabase (required for Auth and DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL for magic link redirect (optional; defaults to VERCEL_URL or localhost:3000)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Python extraction bridge – POST returns PoseData (optional; /api/process-dance-video returns 503 if unset)
# EXTRACTION_SERVICE_URL=http://localhost:8000/extract

# AI – coaching feedback and move descriptions (optional; either key is enough)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Feature flags (optional; default false)
# NEXT_PUBLIC_AUDIO_COACH=true
# NEXT_PUBLIC_PARTNER_MODE=true

# Python scripts (process_pending.py etc.) – use SUPABASE_SERVICE_ROLE_KEY, never NEXT_PUBLIC_
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
